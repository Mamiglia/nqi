# Dockerfile.test
#
# Smoke-tests the nqi installation pipeline in a clean Docker environment.
# Two build stages are provided; select with --target:
#
#   docker build --target test-installer -t nqi-test-installer .
#   docker build --target test-pip       -t nqi-test-pip       .
#
# Or use ./tools/test-install.sh which drives both automatically.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Shared base: Ubuntu LTS with build prerequisites
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FROM ubuntu:24.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update -q && \
    apt-get install -y -q --no-install-recommends \
        gcc make libc6-dev python3 python3-pip pipx git curl \
    && rm -rf /var/lib/apt/lists/*

# Ensure ~/.local/bin is on PATH for the root user in the container
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /src
COPY . .
# Initialise the nq submodule if it wasn't already populated by the host
# (e.g. when building from a shallow/non-recursive clone or an sdist).
RUN if [ ! -f nq/nq.c ]; then \
        mkdir -p nq; \
        if [ -d .git ] && git submodule update --init -- nq 2>/dev/null; then \
            echo "nq submodule initialised"; \
        else \
            echo "git submodule failed or not a submodule, downloading via curl..."; \
            curl -fsSL https://github.com/leahneukirchen/nq/archive/refs/heads/master.tar.gz \
            | tar -xz --strip-components=1 -C nq; \
        fi; \
    fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Stage 1: test the install.sh one-liner
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FROM base AS test-installer

RUN echo "=== Running install.sh ===" && \
    ./install.sh

# Verify the nqi entry-point is on PATH
RUN command -v nqi || { echo "FAIL: nqi not found in PATH"; exit 1; }

# Verify setup.py compiled and bundled nq inside the package
RUN python3 -c "\
import importlib.util, os, sys; \
spec = importlib.util.find_spec('nqi'); \
pkg_dir = os.path.dirname(spec.origin); \
bundled = os.path.join(pkg_dir, 'bin', 'nq'); \
sys.exit(0 if os.path.isfile(bundled) else (print('FAIL: bundled nq not found at', bundled) or 1))"

# Functional smoke-test: enqueue a job via the bundled binary, wait, verify
RUN echo "=== Functional smoke-test ===" && \
    python3 -c "\
import subprocess, os, time, glob; \
os.environ['NQDIR'] = '/tmp/nqtest'; \
os.makedirs('/tmp/nqtest', exist_ok=True); \
from nqi.logic import get_nq_executable; \
nq = get_nq_executable(); \
print('nq binary:', nq); \
subprocess.check_call([nq, 'echo', 'hello from nq']); \
subprocess.check_call([nq, '-w']); \
logs = glob.glob('/tmp/nqtest/,*'); \
assert logs, 'FAIL: no job log files'; \
print('OK: job log created at', logs[0])"


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Stage 2: test pip install (no install.sh, no pre-built bins)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FROM base AS test-pip

RUN echo "=== pip install . ===" && \
    pip3 install --break-system-packages .

# Verify the nqi entry-point was created
RUN command -v nqi || { echo "FAIL: nqi not found in PATH"; exit 1; }

# The setup.py build_py step should have compiled and bundled nq
RUN python3 -c "import importlib.util, os, sys; spec = importlib.util.find_spec('nqi'); pkg_dir = os.path.dirname(spec.origin); bundled = os.path.join(pkg_dir, 'bin', 'nq'); sys.exit(0 if os.path.isfile(bundled) else (print('FAIL: bundled nq not found at', bundled) or 1))"

# Functional smoke-test using the bundled binary via the Python API
RUN python3 -c "import subprocess, os, time, glob; os.environ['NQDIR'] = '/tmp/nqtest'; os.makedirs('/tmp/nqtest', exist_ok=True); from nqi.logic import get_nq_executable; nq = get_nq_executable(); print('nq binary:', nq); subprocess.check_call([nq, 'echo', 'hello from pip-installed nq']); time.sleep(0.5); logs = glob.glob('/tmp/nqtest/,*'); assert logs, 'FAIL: no job log files'; print('OK: job log created at', logs[0])"

RUN python3 -c "from nqi.app import NQI; print('OK nqi.app imported')"
